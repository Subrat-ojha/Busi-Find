# Google Places API Key (optional - enables Google Places API source)
GOOGLE_API_KEY=

# Yelp Fusion API Key (optional - enables Yelp source)
# Get one free at: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# Foursquare API Key (optional - enables Foursquare source)
# Get one free at: https://foursquare.com/developers/signup
FOURSQUARE_API_KEY=
